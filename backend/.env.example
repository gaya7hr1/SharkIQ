# --- App ---
APP_ENV=development
APP_NAME=SharkIQ
API_V1_PREFIX=/api/v1
SECRET_KEY=change-me-to-a-random-64-char-string
ALLOWED_ORIGINS=http://localhost:3000

# --- Database ---
DATABASE_URL=postgresql+asyncpg://sharkiq:sharkiq@localhost:5432/sharkiq
DATABASE_URL_SYNC=postgresql+psycopg2://sharkiq:sharkiq@localhost:5432/sharkiq

# --- OpenAI ---
OPENAI_API_KEY=sk-replace-me
OPENAI_CHAT_MODEL=gpt-4o
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# --- ChromaDB ---
CHROMA_PERSIST_DIR=./storage/chroma
CHROMA_HOST=
CHROMA_PORT=

# --- LangSmith (tracing/debugging for every LangChain & LangGraph run) ---
LANGCHAIN_TRACING_V2=true
LANGCHAIN_API_KEY=ls__replace-me
LANGCHAIN_PROJECT=SharkIQ
LANGCHAIN_ENDPOINT=https://api.smith.langchain.com

# --- Hugging Face Hub ---
HUGGINGFACEHUB_API_TOKEN=hf_replace-me
HF_SENTIMENT_MODEL=distilbert-base-uncased-finetuned-sst-2-english

# --- Storage ---
UPLOAD_DIR=./storage/uploads
REPORTS_DIR=./storage/reports
MAX_UPLOAD_SIZE_MB=25

# --- Auth ---
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=1440

# --- Logging ---
LOG_LEVEL=INFO
